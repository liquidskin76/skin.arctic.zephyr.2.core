                    </include>
                </control>
            </control>
            <control type="group">
                <include content="View_Group">
                    <param name="animation" value="Defs_Null" />
                </include>
                <control type="grouplist">
                    <top>-15</top>
                    <width>2500</width>
                    <left>-30</left>
                    <bottom>-15</bottom>
                    <orientation>horizontal</orientation>
                    <usecontrolcoords>true</usecontrolcoords>
                    <itemgap>0</itemgap>
                    <control type="group" id="300">
                        <width>257.14</width>
                        <left>15</left>
                        <top>40</top>
                        <bottom>7</bottom>
                        <control type="group">
                            <width>257.14</width>
                            <control type="button" id="3002">
                                <onup>SetFocus(302,999,absolute)</onup>
                                <ondown>SetFocus(302,0,absolute)</ondown>
                                <right>40</right>
                                <onleft>301</onleft>
                                <onright>301</onright>
                                <onback>301</onback>
                                <font>font_topbar</font>
                                <align>right</align>
                                <aligny>center</aligny>
                                <textcolor>main_fg_30</textcolor>
                                <focusedcolor>main_fg_100</focusedcolor>
                                <textoffsetx>0</textoffsetx>
                                <texturefocus />
                                <texturenofocus />
                                <label>$INFO[Container(301).ListItem.Label]</label>
                                <onclick>$INFO[Container(301).ListItem.Property(path)]</onclick>
                                <height>item_list_height</height>
                                <include>Animation_Left</include>
                                <visible allowhiddenfocus="true">Control.HasFocus(302) | Control.HasFocus(3002)</visible>
                            </control>
                            <control type="panel" id="302">
                                <include>Animation_Left</include>
                                <visible allowhiddenfocus="true">Control.HasFocus(302) | Control.HasFocus(3002)</visible>
                                <onup>3002</onup>
                                <ondown>3002</ondown>
                                <onleft>301</onleft>
                                <onright>301</onright>
                                <onback>301</onback>
                                <include>Defs_InfoDialog_Visible</include>
                                <left>0</left>
                                <animation effect="fade" start="100" end="0" time="200" condition="ControlGroup(3000).HasFocus() | Control.HasFocus(5000) | Control.HasFocus(5100) | Control.HasFocus(6000)">Conditional</animation>
                                <top>item_list_height</top>
                                <width>257.14</width>
                                <onright>3000</onright>
                                <orientation>vertical</orientation>                
                                <itemlayout width="257.14" height="item_list_height">							
                                    <control type="label">
                                        <right>40</right>
                                        <font>font_submenu_small</font>
                                        <align>right</align>
                                        <aligny>center</aligny>
                                        <textcolor>main_fg_30</textcolor>
                                        <label>$INFO[ListItem.Label]</label>
                                    </control>
                                </itemlayout>
                                <focusedlayout width="257.14" height="item_list_height">									
                                    <control type="label">
                                        <right>40</right>
                                        <font>font_submenu</font>
                                        <align>right</align>
                                        <aligny>center</aligny>
                                        <textcolor>main_fg_100</textcolor>
                                        <label>$INFO[ListItem.Label]</label>
                                    </control>
                                </focusedlayout>
                                <content><include>skinshortcuts-submenu</include></content>
                            </control>
                        </control>
                        <control type="panel" id="301">
                            <visible allowhiddenfocus="true">![Control.HasFocus(302) | Control.HasFocus(3002)]</visible>
                            <include>Animation_Left</include>
                            <include>Defs_InfoDialog_Visible</include>	
                            <onleft condition="Integer.IsGreater(Container(302).NumItems,0)">SetProperty(submenuVisibility,$INFO[Container(301).ListItem.Property(submenuVisibility)],home)</onleft>
                            <onleft condition="Integer.IsGreater(Container(302).NumItems,0)">SetProperty(leftHeader,$INFO[Container(301).ListItem.Label],home)</onleft>
                            <onleft condition="Integer.IsGreater(Container(302).NumItems,0)">SetProperty(widgetName,$INFO[Container(301).ListItem.Property(widgetName)],home)</onleft>
                            <onleft condition="Integer.IsGreater(Container(302).NumItems,0)">SetProperty(widgetName.backgroundWidget,$INFO[Container(301).ListItem.Property(widgetName.backgroundWidget)],home)</onleft>
                            <onleft condition="Integer.IsGreater(Container(302).NumItems,0)">SetProperty(widgetPath,$INFO[Container(301).ListItem.Property(widgetPath)],home)</onleft>
                            <onleft condition="Integer.IsGreater(Container(302).NumItems,0)">SetProperty(widgetTarget,$INFO[Container(301).ListItem.Property(widgetTarget)],home)</onleft>
                            <onleft condition="Integer.IsGreater(Container(302).NumItems,0)">SetProperty(widgetAspect,$INFO[Container(301).ListItem.Property(widgetAspect)],home)</onleft>
                            <onleft condition="Integer.IsGreater(Container(302).NumItems,0)">ActivateWindow(1135)</onleft>							
                            <animation effect="fade" start="100" end="0" time="200" condition="ControlGroup(3000).HasFocus() | Control.HasFocus(5000) | Control.HasFocus(5100) | Control.HasFocus(6000)">Conditional</animation>
                            <top>0</top>
                            <onright condition="!String.IsEqual(Container(9989).ListItem.Property(list),Settings) + !String.IsEqual(Container(9989).ListItem.Property(list),Weather)">3000</onright>
                            <onright condition="String.IsEqual(Container(9989).ListItem.Property(list),Settings)">5000</onright>
                            <onright condition="String.IsEqual(Container(9989).ListItem.Property(list),Weather)">6000</onright>
                            <width>257.14</width>
                            <orientation>vertical</orientation>                
                            <itemlayout width="257.14" height="item_list_height">
                                <control type="label">
                                    <right>60</right>
                                    <font>font_topbar_small</font>
                                    <align>right</align>
                                    <aligny>center</aligny>
                                    <textcolor>main_fg_30</textcolor>
                                    <label>$INFO[ListItem.Label]</label>
                                </control>
                            </itemlayout>
                            <focusedlayout width="257.14" height="item_list_height">
								<control type="image">
									<left>0</left>
									<top>7</top>
									<width>1</width>
									<height>64</height>
									<texture colordiffuse="white">common/white.png</texture>
									<animation effect="slide" start="0" end="-65" time="0" condition="Control.HasFocus(301) | Window.IsVisible(shutdownmenu)">Conditional</animation>
								</control>							
                                <control type="label">
                                    <right>60</right>
                                    <font>font_topbar</font>
                                    <align>right</align>
                                    <aligny>center</aligny>
                                    <textcolor>main_fg_100</textcolor>
                                    <label>$INFO[ListItem.Label]</label>
                                </control>
                            </focusedlayout>
                            <content><include>skinshortcuts-mainmenu</include></content>
                        </control>
                    </control>                   
                    <control type="group" id="99300">
                        <height>view_height</height>
                        <width>1800</width>
                        <include>Animation_Right</include>
                        <include>Defs_InfoDialog_Visible</include>
						<animation effect="fade" start="100" end="80" time="200" condition="!Control.HasFocus(993100)">Conditional</animation>						
						<control type="grouplist" id="3000">
                            <visible>!String.IsEqual(Container(9989).ListItemAbsolute(0).Property(list),Settings) + !String.IsEqual(Container(9989).ListItemAbsolute(0).Property(list),Weather)</visible>
                            <top>45</top>
							<right>-40</right>
                            <onup>301</onup>
                            <ondown>301</ondown>
                            <onleft>301</onleft>
                            <scrolltime tween="quadratic">400</scrolltime>
                            <height>view_height</height>
                            <width>1800</width>
                            <orientation>vertical</orientation>
                            <itemgap>-52</itemgap>
                            <usecontrolcoords>true</usecontrolcoords>
                            <control type="group" id="7999"><height>0</height></control>
                            <!-- <include>skinshortcuts-template-vertical-submenu</include> -->
                            <include>skinshortcuts-template-vertical-main</include>
                        </control>
                        <control type="group">
                            <visible>Integer.IsEqual(Container(3000).NumItems,1)</visible>
                            <visible>!String.IsEqual(Container(9989).ListItemAbsolute(0).Property(list),Settings) + !String.IsEqual(Container(9989).ListItemAbsolute(0).Property(list),Weather)</visible>
                            <top>477.5</top>
                            <left>55</left>
                            <right>15</right>
                            <bottom>0</bottom>
                            <control type="group">
                                <top>15</top>
                                <visible>ControlGroup(3000).HasFocus()</visible>
                                <include content="View_52_Showcase_Aura_Info">
                                    <param name="font" value="font_title" />
                                    <param name="plotheight" value="160" />
                                    <param name="titleheight" value="60" />
                                </include>
                            </control>
                            <control type="group">
                                <width>1500</width>
                                <visible>!ControlGroup(3000).HasFocus()</visible>
                                <visible>!Control.IsVisible(993100)</visible>
                                <include>skinshortcuts-template-vertical-info</include>
                            </control>
                            <control type="group">
                                <width>1500</width>
                                <visible>!ControlGroup(3000).HasFocus()</visible>
                                <visible>Control.IsVisible(993100)</visible>
                                <include content="Home_Vertical_Info">
                                    <param name="font" value="font_title" />
                                    <param name="plotheight" value="160" />
                                    <param name="titleheight" value="60" />
                                    <param name="id" value="993100" />
                                    <param name="uid" value="993" />
                                </include>
                            </control>
                        </control>
                    </control>
                </control>
            </control>
        </control>	
    </include>
	<!-- Vertical Menu -->	
 	
	
	<!-- Spotlight Info -->		
	<include name="Home_Vertical_Info">
        <param name="plotheight" default="120" />
        <definition>
            <control type="grouplist">
                <nested />
                <animation effect="fade" end="50" condition="true">Conditional</animation>
                <visible>!String.IsEmpty(Container($PARAM[id]).ListItem.Title)</visible>
                <orientation>vertical</orientation>
                <usecontrolcoords>true</usecontrolcoords>
                <itemgap>0</itemgap>
                <include content="Object_Info_Title">
                    <param name="label" value="$INFO[Container($PARAM[id]).ListItem.Title]" />
                    <param name="font" value="$PARAM[font]" />
                    <param name="titleheight" value="$PARAM[titleheight]" />
                </include>
                <include content="Object_Info_Line">
                    <param name="container" value="Container($PARAM[id])." />
                    <param name="uid" value="$PARAM[uid]" />
                </include>
                <control type="group">
                    <top>-5</top>
                    <height>75</height>
                    <visible>!Skin.HasSetting(DisableStarRating)</visible>
                    <visible>!Skin.HasSetting(NumericStarRating)</visible>
                    <control type="group">
                        <left>-14</left>
                        <visible>String.IsEmpty(Container($PARAM[id]).ListItem.UserRating)</visible>
                        <include content="Object_StarRating">
                            <param name="rating_prop" value="Container($PARAM[id]).ListItem.Rating" />
                        </include>
                    </control>
                    <control type="group">
                        <left>-14</left>
                        <visible>!String.IsEmpty(Container($PARAM[id]).ListItem.UserRating)</visible>
                        <include content="Object_StarRating">
                            <param name="rating_prop" value="Container($PARAM[id]).ListItem.UserRating" />
                        </include>
                    </control>
                </control>
                <control type="group">
                    <top>-5</top>
                    <height>75</height>
                    <visible>!Skin.HasSetting(DisableStarRating)</visible>
                    <visible>Skin.HasSetting(NumericStarRating)</visible>
                    <control type="group">
                        <left>-14</left>
                        <top>24</top>
                        <visible>!String.IsEmpty(Container($PARAM[id]).ListItem.Rating)</visible>
                        <control type="image">
                            <width>64</width>
                            <height>64</height>
                            <texture colordiffuse="main_fg_100">flags/star10.png</texture>
                        </control>
                        <control type="label">
                            <left>61</left>
                            <textcolor>main_fg_70</textcolor>
                            <top>19</top>
                            <width>auto</width>
                            <height>28</height>
                            <align>right</align>
                            <font>font_tiny</font>
                            <label>$INFO[Container($PARAM[id]).ListItem.Rating,,   ]</label>
                        </control>
                    </control>
                </control>
                <include content="Object_Info_Plot">
                    <param name="label" value="$INFO[Container($PARAM[id]).ListItem.Plot]" />
                    <param name="maxheight" value="$PARAM[plotheight]" />
                </include>
            </control>
        </definition>
    </include>
	<!-- Spotlight Info -->


	<!-- Optional Submenu Hub -->	
    <include name="Home_Hub_Widget">
        <param name="widget" default="true" />
        <param name="widgetvisibility" default="true" />
        <definition>
            <control type="panel" id="302">
                <nested />
                <scrolltime tween="quadratic">400</scrolltime>
